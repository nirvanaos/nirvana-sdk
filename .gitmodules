[submodule "nirvana/library"]
	path = nirvana/library
	url = https://github.com/nirvanaos/library.git
	branch = master
[submodule "nirvana/orb"]
	path = nirvana/orb
	url = https://github.com/nirvanaos/orb.git
	branch = master
[submodule "googletest/googletest"]
	path = googletest/googletest
	url = https://github.com/nirvanaos/googletest.git
	branch = nirvana
[submodule "openlibm"]
	path = openlibm
	url = https://github.com/JuliaMath/openlibm.git
[submodule "llvm-project"]
	path = llvm-project
	url = https://github.com/llvm/llvm-project.git
	shallow = true
